OPC_APP_NAME=OPC Development
OPC_DATABASE_URL=sqlite:///./opc.db
OPC_WORKSPACE_ROOT=/tmp/opc/projects
OPC_LLM_MODEL=gpt-5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional per-agent model overrides
OPC_DIRECTOR_MODEL=gpt-5
OPC_PM_MODEL=gpt-5
OPC_PLANNER_MODEL=gpt-5
OPC_CODER_MODEL=gpt-5
OPC_DEBUGGER_MODEL=gpt-5
OPC_REVIEWER_MODEL=gpt-5

OPC_DOCKER_PREPARE_TIMEOUT=120
OPC_DOCKER_TEST_TIMEOUT=120
OPC_INTERNAL_TOKEN=replace-with-opc-internal-token
WECOM_BRIDGE_NOTIFY_URL=http://127.0.0.1:9001/internal/notify
WECOM_BRIDGE_NOTIFY_TOKEN=replace-with-bridge-notify-token
WECOM_NOTIFY_TIMEOUT=5

# Optional direct WeCom app configuration used by the main service
WECOM_AGENT_ID=
WECOM_CORP_ID=
WECOM_CORP_SECRET=

# WeCom bridge configuration
WECOM_BOT_ID=replace-with-wecom-bot-id
WECOM_BOT_SECRET=replace-with-wecom-bot-secret
WECOM_BRIDGE_HOST=127.0.0.1
WECOM_BRIDGE_PORT=9001
OPC_BASE_URL=http://127.0.0.1:8000
WECOM_BRIDGE_REQUEST_TIMEOUT=10
WECOM_BRIDGE_RECONNECT_INTERVAL=1000
WECOM_BRIDGE_MAX_RECONNECT_ATTEMPTS=10
WECOM_BRIDGE_HEARTBEAT_INTERVAL=30000
WECOM_BRIDGE_WS_URL=
